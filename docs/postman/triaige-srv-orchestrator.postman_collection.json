{
  "info": {
    "name": "triaige-srv-orchestrator",
    "description": "Coleção de requisições para testar localmente o triaige-srv-orchestrator (perfil dev, H2 + LocalStack). Importável no Postman ou Insomnia.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "lawFirmId", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "sessionId", "value": "" },
    { "key": "documentId", "value": "" },
    { "key": "correlationId", "value": "" }
  ],
  "item": [
    {
      "name": "Sessions",
      "item": [
        {
          "name": "Criar sessão",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.sessionId) pm.collectionVariables.set(\"sessionId\", body.sessionId);",
                  "if (body.correlationId) pm.collectionVariables.set(\"correlationId\", body.correlationId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Law-Firm-Id", "value": "{{lawFirmId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lawFirmId\": \"{{lawFirmId}}\",\n  \"titulo\": \"Reclamação trabalhista - horas extras\",\n  \"areaJuridica\": \"TRABALHISTA\",\n  \"tipoCaso\": \"RECLAMACAO_TRABALHISTA\",\n  \"remetente\": {\n    \"nome\": \"João Silva\",\n    \"email\": \"joao@email.com\",\n    \"telefone\": \"+5511999999999\",\n    \"canalPreferencial\": \"EMAIL\"\n  }\n}"
            }
          }
        },
        {
          "name": "Registrar documento",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.documentId) pm.collectionVariables.set(\"documentId\", body.documentId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Law-Firm-Id", "value": "{{lawFirmId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/documents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", "{{sessionId}}", "documents"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" },
                { "key": "tipoDocumento", "type": "text", "value": "PETICAO_INICIAL" },
                { "key": "ultimoDocumento", "type": "text", "value": "false" }
              ]
            }
          }
        },
        {
          "name": "Registrar documento (último - dispara processamento)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.documentId) pm.collectionVariables.set(\"documentId\", body.documentId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Law-Firm-Id", "value": "{{lawFirmId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/documents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", "{{sessionId}}", "documents"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" },
                { "key": "tipoDocumento", "type": "text", "value": "PETICAO_INICIAL" },
                { "key": "ultimoDocumento", "type": "text", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Disparar processamento",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Law-Firm-Id", "value": "{{lawFirmId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/process",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", "{{sessionId}}", "process"]
            }
          }
        },
        {
          "name": "Consultar sessão",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Law-Firm-Id", "value": "{{lawFirmId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", "{{sessionId}}"]
            }
          }
        },
        {
          "name": "Consultar eventos da sessão",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Law-Firm-Id", "value": "{{lawFirmId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", "{{sessionId}}", "events"]
            }
          }
        }
      ]
    },
    {
      "name": "Internal Callbacks",
      "item": [
        {
          "name": "Pré-processamento concluído",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/internal/api/v1/sessions/{{sessionId}}/pre-processing/completed",
              "host": ["{{baseUrl}}"],
              "path": ["internal", "api", "v1", "sessions", "{{sessionId}}", "pre-processing", "completed"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correlationId\": \"{{correlationId}}\",\n  \"processedDocuments\": [\n    {\n      \"documentId\": \"{{documentId}}\",\n      \"rawBucket\": \"triaige-raw-documents\",\n      \"rawObjectKey\": \"law-firm/{{lawFirmId}}/sessions/{{sessionId}}/raw/peticao-inicial.pdf\",\n      \"processedBucket\": \"triaige-processed-documents\",\n      \"processedObjectKey\": \"law-firm/{{lawFirmId}}/sessions/{{sessionId}}/processed/peticao-inicial.txt\",\n      \"status\": \"PROCESSADO\"\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Processamento de IA concluído",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/internal/api/v1/sessions/{{sessionId}}/ai-processing/completed",
              "host": ["{{baseUrl}}"],
              "path": ["internal", "api", "v1", "sessions", "{{sessionId}}", "ai-processing", "completed"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correlationId\": \"{{correlationId}}\",\n  \"status\": \"CONCLUIDO\",\n  \"resultBucket\": \"triaige-results\",\n  \"resultObjectKey\": \"law-firm/{{lawFirmId}}/sessions/{{sessionId}}/result/resultado.json\",\n  \"summaryObjectKey\": \"law-firm/{{lawFirmId}}/sessions/{{sessionId}}/result/resumo.txt\",\n  \"jurisprudenceUsed\": true\n}"
            }
          }
        }
      ]
    }
  ]
}
